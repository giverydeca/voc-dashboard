# ---- start ----
Import-DotEnv $EnvPath

if (-not $env:OPENAI_API_KEY) { throw "OPENAI_API_KEY is not set. (.env: $EnvPath)" }
if (-not (Test-Path $InputTsv)) { throw "Input not found: $InputTsv" }
if (-not (Test-Path $InstrPath)) { throw "instructions2.txt not found: $InstrPath" }

New-Item -ItemType Directory -Force -Path (Split-Path $OutTsv) | Out-Null
$utf8bom = New-Object System.Text.UTF8Encoding($true)

$instr = Get-Content $InstrPath -Raw
$rows = Import-Csv -Path $InputTsv -Delimiter "`t"

$headerCsv = "問い合わせID,お問い合わせ日,顧客属性,問い合わせ元サイト,大区分NO,大区分名,小区分NO,小区分名,ユーザーの意図(Intent),意図要約(短),対象機能(Target Function),Webサイトのバリア(Barrier),バリア要約(短),Web自己解決可能性,推定発生ページ,発生タイミング,WEBオーダー番号,商品の注文番号,商品名,重要キーワード,緊急度,問い合わせ要約,顧客の生の声,本文(整形済),商品カテゴリ小カテゴリ"
$headerTsv = $headerCsv -replace ",","`t"

if (-not (Test-Path $OutTsv)) {
  [System.IO.File]::WriteAllLines($OutTsv, @($headerTsv), $utf8bom)
}
if (-not (Test-Path $ErrTsv)) {
  [System.IO.File]::WriteAllLines($ErrTsv, @("rowIndex`terror"), $utf8bom)
}

$N = [Math]::Min($rows.Count, $Limit)
Write-Host ("START model={0} rows={1} limit={2}" -f $Model, $rows.Count, $N)

for ($i=0; $i -lt $N; $i++){
  $date = $rows[$i]."お問い合わせ日"
  $bodyText = $rows[$i]."内容"
  if (-not $date) { $date = "不明" }
  if (-not $bodyText) { $bodyText = "不明" }

  $oneInput = "$date`t$bodyText"

  $prompt = @"
$instr

#DATA
以下は入力TSVの「データ行1件」です（2列、タブ区切り）。

$oneInput
"@

  $ok = $false
  $lastErr = ""

  for ($try=1; $try -le $MaxRetry; $try++){
    try{
      $raw = Invoke-OpenAI -prompt $prompt -model $Model
      $lines = Sanitize-Lines $raw
      if ($lines.Count -lt 1) { throw "Empty output" }
      if ($lines.Count -gt 3) { $lines = $lines | Select-Object -First 3 }

      foreach($ln in $lines){
        if (-not (Is-Valid25 $ln)){
          throw "Invalid TSV columns (expected 25): $ln"
        }
      }

      foreach($ln in $lines){
        [System.IO.File]::AppendAllText($OutTsv, $ln + "`r`n", $utf8bom)
      }

      $ok = $true
      break
    } catch {
      $lastErr = $_.Exception.Message
      Start-Sleep -Seconds (2 * $try)
    }
  }

  if (-not $ok){
    $msg = ("{0}`t{1}" -f $i, ($lastErr -replace "`r|`n"," "))
    [System.IO.File]::AppendAllText($ErrTsv, $msg + "`r`n", $utf8bom)
  }

  Write-Host ("[progress] {0}/{1}" -f ($i+1), $N)
}

Write-Host "DONE"
Write-Host ("OUT: {0}" -f $OutTsv)
Write-Host ("ERR: {0}" -f $ErrTsv)





